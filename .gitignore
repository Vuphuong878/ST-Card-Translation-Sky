# Local translation progress cache (per-card, filesystem)
translation-progress/

# Local card-creator project cache (per-project, filesystem) — user data, never committed
# so the in-app Update (git pull) can't touch work-in-progress. Matches at any depth,
# incl. tao-card/card-progress/.
card-progress/

# Next.js build output (mod-card)
.next/

# Local dev scratch: EJS dumps, message drafts, diffs — never part of the app
_dev-scratch/
translation_debug.log

# dev_data: thẻ test + fixture card-lỗi (dùng cho test surgical local) + scratch tạm.
# Dùng cục bộ, KHÔNG commit vào repo. File đã tracked trước đó (JB.txt, novalcard-vi.html,
# *.json) vẫn giữ nguyên — gitignore không gỡ file đã tracked.
dev_data/*.html
dev_data/*.js
dev_data/message.txt
dev_data/*.json
dev_data/message*.txt
tsconfig.tsbuildinfo
*.tsbuildinfo

# Secrets & test data — KHONG commit
apiKey/
cardTest/
